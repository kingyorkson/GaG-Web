{
  "name": "growing-gardening-windows",
  "version": "1.0.0",
  "description": "Growing & Gardening 2D - A multiplayer gardening game",
  "author": "Growing Gardening Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.growinggardening.app",
    "productName": "Growing & Gardening 2D",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "../web/dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  }
}
